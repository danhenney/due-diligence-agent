# === API 버전 (Streamlit/CLI) 필수 키 ===
# Anthropic API Key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === DD Local (/dd-local) + API 공통 필수 키 ===
# Tavily — https://app.tavily.com (무료 1000회/월)
TAVILY_API_KEY=your_tavily_api_key_here

# === 선택 키 (없어도 작동, 있으면 분석 품질 향상) ===
# DART (한국 기업 재무제표) — https://opendart.fss.or.kr
DART_API_KEY=
# FRED (거시경제 데이터) — https://fred.stlouisfed.org
FRED_API_KEY=
# GitHub (리포 분석) — https://github.com/settings/tokens
GITHUB_TOKEN=
# SEC EDGAR User Agent
EDGAR_USER_AGENT="Your Name your.email@example.com"

# === API 버전 전용 ===
CHECKPOINT_DB_PATH=./checkpoints.db
REPORTS_DIR=./reports
